{
  "name": "hunter-realestate-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "modules/crawler",
    "modules/pipeline",
    "modules/gateway",
    "modules/dashboard",
    "shared/types"
  ],
  "scripts": {
    "dev": "docker-compose up --build",
    "dev:crawler": "cd modules/crawler && npm run dev",
    "dev:pipeline": "cd modules/pipeline && npm run dev",
    "dev:gateway": "cd modules/gateway && npm run dev",
    "dev:dashboard": "cd modules/dashboard && npm run dev",
    "test": "jest --passWithNoTests --runInBand",
    "lint": "eslint . --ext .ts,.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "typescript": "^5.3.0",
    "ts-jest": "^29.0.0"
  }
}
