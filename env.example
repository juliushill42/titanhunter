# ============================================================
# Hunter Real Estate System — Environment Variables
# Copy to .env and fill in real values before running
# NEVER commit .env to version control
# ============================================================

# ── Database ────────────────────────────────────────────────
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_URL=postgresql://hunter:your_secure_password_here@localhost:5432/hunter_db

# ── Message Queue ────────────────────────────────────────────
KAFKA_BROKERS=localhost:29092

# ── Cache ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI / LLM ────────────────────────────────────────────────
# Primary: Claude (via Anthropic API)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Secondary: GPT-4o (swap in pipeline/.env if needed)
# OPENAI_API_KEY=sk-your-openai-key-here
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o

# ── Payments (Module C) ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
TITAN_MULTISIG_SECRET=64_char_random_hex_minimum_entropy_required_here_generate_new

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=64_char_random_hex_minimum_entropy_required_here_generate_new

# ── Orchestra Webhooks ───────────────────────────────────────
ORCHESTRA_WEBHOOK_URL=https://your-orchestra-endpoint.titanuai.com/webhooks
ORCHESTRA_WEBHOOK_SECRET=another_64_char_random_hex

# ── Market Data APIs ─────────────────────────────────────────
COUNTY_API_KEY=your_county_records_api_key
MLS_API_KEY=your_mls_api_key

# ── Proxy Config ─────────────────────────────────────────────
# Comma-separated list of proxy URLs for rotation
PROXY_LIST=http://proxy1:port,http://proxy2:port

# ── CRM Export Targets ───────────────────────────────────────
HUBSPOT_API_KEY=your_hubspot_key
SALESFORCE_CLIENT_ID=your_sf_client_id
SALESFORCE_CLIENT_SECRET=your_sf_client_secret
FOLLOWUPBOSS_API_KEY=your_fub_key
